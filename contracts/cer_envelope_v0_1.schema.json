{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CER Envelope v0.1 Bridge Demo",
  "type": "object",
  "required": [
    "contract_version",
    "schema_version",
    "canonical_json_version",
    "run_id",
    "record_type",
    "export_timestamp",
    "provenance_hash",
    "payload"
  ],
  "properties": {
    "contract_version": { "const": "0.1" },
    "schema_version": { "const": "0.1" },
    "canonical_json_version": { "const": "canonical-json-v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "record_type": {
      "type": "string",
      "enum": ["metric_observation", "gate_outcome", "cohort_partition"]
    },
    "export_timestamp": { "type": "string", "minLength": 1 },
    "provenance_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "payload": { "type": "object", "minProperties": 1 }
  },
  "additionalProperties": false
}
