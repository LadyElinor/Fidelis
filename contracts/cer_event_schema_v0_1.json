{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CER Event Envelope v0.1",
  "type": "object",
  "required": [
    "contract_version",
    "schema_version",
    "export_timestamp",
    "record_type",
    "run_id",
    "provenance_hash",
    "payload"
  ],
  "properties": {
    "contract_version": {"const": "0.1"},
    "schema_version": {"const": "0.1"},
    "export_timestamp": {"type": "string"},
    "record_type": {
      "type": "string",
      "enum": ["run", "hazard_map", "gate_check", "confirmation", "external_action", "data_issue"]
    },
    "run_id": {"type": "string", "minLength": 1},
    "provenance_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "payload": {"type": "object"}
  },
  "additionalProperties": false
}
