{
  "name": "cer-telemetry-improved",
  "version": "2.0.0",
  "description": "Enhanced CER-Telemetry pipeline with modular architecture and advanced analysis",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test test/**/*.test.js",
    "test:watch": "node --test --watch test/**/*.test.js",
    "lint": "eslint .",
    "analyze": "node src/cli.js analyze",
    "validate": "node src/cli.js validate",
    "report": "node src/cli.js report",
    "quickstart": "node examples/minimal_pipeline/run_minimal_pipeline.js",
    "cer:pipeline": "node examples/cer_pipeline/run_cer_pipeline.js",
    "regime:pipeline": "node examples/regime_frontier_pipeline/run_regime_frontier_pipeline.js",
    "physics:pipeline": "node examples/physics_pipeline/run_physics_pipeline.js",
    "hodge:nl:pipeline": "node examples/hodge_nl_pipeline/run_hodge_nl_pipeline.js",
    "strategy:rank": "node examples/strategy_prioritization/run_strategy_ranking.js",
    "alignment:eval": "node examples/alignment_eval/run_alignment_eval.js",
    "alignment:calibrate": "node examples/alignment_eval_calibration/run_alignment_calibration.js",
    "alignment:policy-patch": "node examples/alignment_eval_calibration/run_generate_policy_patch.js"
  },
  "keywords": [
    "telemetry",
    "observability",
    "safety",
    "content-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.4",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "csv-writer": "^1.6.0",
    "csv-parse": "^5.5.2",
    "simple-statistics": "^7.8.3",
    "d3": "^7.8.5",
    "apache-arrow": "^14.0.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jsdoc": "^4.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
